# Server-side API keys (used by /api/ routes, never exposed to browser)
# Set these in Vercel Environment Variables for production
# Create .env.local with these for local development
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=sk_...

# Optional: use ONE voice ID from *your* ElevenLabs account (Voices → ⋮ → Copy voice ID).
# Helps if the API returns paid_plan_required for built-in "library" voices (free-tier keys).
# ELEVENLABS_DEFAULT_VOICE_ID=
